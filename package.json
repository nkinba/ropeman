		"@types/node": "^25.3.3",
		"@types/prismjs": "^1.26.6",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"eslint": "^10.0.2",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.1",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"svelte": "^5.52.0",
