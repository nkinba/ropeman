	"dependencies": {
		"@dagrejs/dagre": "^1.1.4",
		"@mlc-ai/web-llm": "^0.2.82",
		"@orama/orama": "^3.1.5",
		"@xyflow/svelte": "^1.0.0",
		"html-to-image": "^1.11.13",
